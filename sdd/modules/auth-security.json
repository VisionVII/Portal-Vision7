{
  "module": "Auth & Security Core",
  "version": "2.0.0",
  "owner": "Vision7 Core Team",
  "status": "Production Design Ready",
  "last_updated": "2026-05-02",
  "objective": "Arquitetura de autenticação e autorização de nível SaaS enterprise baseada em OTP, RBAC dinâmico, Security Gate centralizado, risk scoring adaptativo, proteção anti-abuso, auditabilidade imutável e observabilidade completa de segurança.",

  "architecture": {
    "security_gateway": "Centralized Security Gate (single decision point for all sensitive operations)",
    "decision_engine": "Risk-based decision system (0-100 score)",
    "auth_model": "OTP-based authentication + JWT short-lived tokens",
    "session_model": "Device-bound sessions with fingerprinting",
    "rbac_model": "Dynamic RBAC via database (JSONB-ready)",
    "audit_model": "Append-only immutable audit log with hash chaining"
  },

  "security_gateway_flow": {
    "input": "Any sensitive request (login, OTP, invite, admin action, session refresh)",
    "pipeline": [
      "Request Ingestion",
      "Context Builder (IP, UA, Device, Geo, Action)",
      "Risk Engine Evaluation",
      "Decision Engine (ALLOW | CHALLENGE | BLOCK)",
      "Action Execution",
      "Audit Logging"
    ]
  },

  "decision_model": {
    "risk_score_range": "0-100",
    "classification": {
      "ALLOW": "0-39",
      "CHALLENGE": "40-69",
      "BLOCK": "70-100"
    },
    "actions": {
      "ALLOW": ["Proceed normally"],
      "CHALLENGE": ["OTP revalidation", "MFA required", "Device verification"],
      "BLOCK": ["Temporary ban", "Cooldown", "Security flag"]
    }
  },

  "risk_engine": {
    "inputs": [
      "IP reputation",
      "User-Agent entropy",
      "Device fingerprint mismatch",
      "Geolocation change",
      "OTP failure rate",
      "Login velocity",
      "Admin action anomalies",
      "Session age"
    ],
    "scoring_rules": [
      "New device +15",
      "Country change +25",
      "OTP failure +20 per attempt",
      "Rapid login attempts +30",
      "Suspicious admin action +40"
    ],
    "output": {
      "risk_score": "integer (0-100)",
      "confidence": "float (0-1)",
      "reasoning_tags": ["geo_change", "otp_failure", "device_mismatch"]
    }
  },

  "authentication": {
    "method": "OTP-based (passwordless)",
    "otp_policy": {
      "expiration": "5 minutes",
      "max_requests_per_minute": 5,
      "max_requests_per_hour_ip": 10,
      "lockout_threshold": 10
    },
    "mfa_support": {
      "totp": "planned",
      "webauthn": "planned",
      "required_roles": ["admin", "super_admin"]
    }
  },

  "authorization": {
    "model": "RBAC + hierarchical entry system",
    "roles": [
      "public",
      "user",
      "partner",
      "admin",
      "super_admin"
    ],
    "entry_points": {
      "admin": "/acesso/admin/controlado",
      "team": "/validar/entrada/tipodeuser",
      "public": "/request-access"
    }
  },

  "session_security": {
    "jwt": {
      "ttl_seconds": 900,
      "refresh_rotation": true,
      "revocation_enabled": true
    },
    "device_binding": {
      "enabled": true,
      "fingerprint_sources": [
        "IP",
        "User-Agent",
        "Browser fingerprint hash"
      ]
    },
    "session_rules": [
      "Session invalidated on device mismatch",
      "Session expires after inactivity timeout",
      "Session revalidation on risk increase"
    ]
  },

  "invite_system": {
    "security_model": {
      "token_type": "UUID v4 hashed",
      "single_use": true,
      "expiration_hours": 24,
      "email_bound": true
    },
    "abuse_prevention": [
      "Rate-limited invite generation",
      "IP tracking",
      "Role-based quota limits"
    ]
  },

  "audit_system": {
    "model": "append-only immutable log",
    "fields": [
      "id",
      "actor_id",
      "action",
      "target_id",
      "risk_score",
      "ip",
      "user_agent",
      "prev_hash",
      "event_hash",
      "created_at"
    ],
    "properties": [
      "tamper-resistant",
      "chain-hashed integrity",
      "queryable by risk level",
      "partition-ready for scale"
    ]
  },

  "abuse_protection": {
    "mechanisms": [
      "Rate limiting (multi-layer)",
      "Behavior anomaly detection",
      "Invisible CAPTCHA fallback",
      "Temporary IP/device blocking",
      "Risk escalation system"
    ]
  },

  "observability": {
    "security_metrics": [
      "login_success_rate",
      "otp_failure_rate",
      "risk_score_distribution",
      "blocked_requests",
      "challenge_rate",
      "admin_action_frequency",
      "geo_anomaly_events"
    ],
    "logging_level": "structured JSON logs",
    "security_dashboard": "planned"
  },

  "ci_cd_security": {
    "controls": [
      "Secret scanning (Gitleaks)",
      "Dependency vulnerability scanning",
      "PR blocking on critical vulnerabilities",
      "Security policy enforcement in CI"
    ]
  },

  "scalability_design": {
    "principles": [
      "Stateless auth layer",
      "Security Gate as independent service",
      "Risk engine horizontally scalable",
      "Audit logs partitioned by time",
      "RBAC stored in flexible JSONB schema"
    ],
    "multi_tenant_ready": true
  },

  "security_principles": [
    "Passwordless authentication reduces attack surface",
    "Centralized Security Gate ensures deterministic access control",
    "Risk-based adaptive authentication increases resilience",
    "Immutable audit logs ensure forensic integrity",
    "Device binding mitigates session hijacking",
    "Rate limiting prevents brute force and abuse",
    "Short-lived JWT reduces token replay impact",
    "Behavior analysis improves anomaly detection over time"
  ]
}