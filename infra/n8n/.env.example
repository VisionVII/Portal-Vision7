# ─────────────────────────────────────────────────────────────────────────────
# n8n — Variáveis de ambiente (COPIAR para .env e preencher)
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (DB dedicado ou Supabase) ──────────────────────────────────────
N8N_DB_HOST=n8n-db                     # "n8n-db" se usar o container local, ou "db.xxx.supabase.co"
N8N_DB_PORT=5432
N8N_DB_NAME=n8n
N8N_DB_USER=n8n_service
N8N_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS
N8N_DB_SCHEMA=n8n
N8N_DB_EXTERNAL_PORT=5433              # Porta exposta no host (apenas para debug)

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_PORT=5678
N8N_ENCRYPTION_KEY=CHANGE_ME_RANDOM_32_CHAR_KEY
N8N_API_KEY=CHANGE_ME_API_KEY_FOR_EDGE_FUNCTION
N8N_WEBHOOK_URL=https://n8n.vision7.pt
N8N_EDITOR_BASE_URL=https://n8n.vision7.pt

# ── Supabase Edge Function Secrets (definir via supabase secrets set) ─────────
# supabase secrets set N8N_BASE_URL="https://n8n.vision7.pt"
# supabase secrets set N8N_API_KEY="<mesmo valor de N8N_API_KEY acima>"
# supabase secrets set N8N_PROXY_ALLOWED_ORIGINS="https://vision7.pt,https://www.vision7.pt"
