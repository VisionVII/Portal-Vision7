# ==============================================================
# VARIÁVEIS DE AMBIENTE — Vision VII Portal
# ==============================================================
# Onde configurar cada variável:
#
#   [LOCAL]   = apenas .env local (development)
#   [VERCEL]  = Settings → Environment Variables no Vercel
#   [SUPA]    = Supabase Dashboard → Edge Functions → Secrets
#   [AMBOS]   = .env local + Vercel
#
# NUNCA commitar o .env real. Este ficheiro é apenas exemplo.
# ==============================================================

# ── Supabase ─────────────────────────────────────────────────
# URL base do seu projeto Supabase
# Onde encontrar: Supabase Dashboard → Settings → API → Project URL
# Configurar em: [AMBOS]
VITE_SUPABASE_URL=https://SEU-PROJECT-ID.supabase.co

# Chave anon/pública do Supabase (NÃO é a service_role!)
# Onde encontrar: Supabase Dashboard → Settings → API → anon public
# Configurar em: [AMBOS]
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# ── Admin / Segurança ────────────────────────────────────────
# Email do administrador principal (bootstrap de permissões)
# O primeiro login com este email recebe role super_admin automaticamente
# Configurar em: [AMBOS]
VITE_ADMIN_PRIMARY_EMAIL=admin@dominio/email.pt

# ── n8n (Automação) ─────────────────────────────────────────
# As credenciais do n8n ficam APENAS nos Secrets do Supabase (Edge Function).
# O frontend chama o n8n via proxy seguro — nunca diretamente.
#
# Configurar em: [SUPA] Supabase Dashboard → Edge Functions → Manage Secrets
# N8N_BASE_URL=https://dominio-dominio.onrender.com
# N8N_API_KEY=sua-api-key-do-n8n
# N8N_PROXY_ALLOWED_ORIGINS=https://dominio.pt,https://www.dominio.pt
#
# Keep-alive 24/7 via Vercel Cron (ping direto ao healthcheck do Render).
# Configurar em: [VERCEL] Environment Variables
# N8N_KEEPALIVE_URL=https://dominio-dominio.onrender.com/healthz
#
# Para persistência no Render (free tier): ver infra/n8n/render-env-vars.txt

# ── Email (Resend) — apenas Edge Functions ───────────────────
# Chave de API do Resend para envio de emails transacionais
# Onde encontrar: https://resend.com/api-keys → Create API Key
# NÃO colocar no .env local nem no Vercel — vai nos Secrets do Supabase
# Configurar em: [SUPA] Supabase Dashboard → Edge Functions → Manage Secrets
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Endereço remetente dos emails (formato: "Nome <email>")
# O domínio deve estar verificado no Resend → Domains
# Configurar em: [SUPA]
FROM_EMAIL=Vision VII <noreply@vision7.pt>
